# Supabase — copy to `.env` for local development.
# In production these are set in Netlify → Site settings → Environment variables.
SUPABASE_URL=https://lgldchystppntwuqkdnv.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# Public site origin used to build the links in confirmation / password-reset
# emails. Set this in production (e.g. https://thelist.example.com); behind a
# proxy the request URL can resolve to localhost, which is why those links
# otherwise come back pointing at localhost. Must also be listed under Supabase
# → Authentication → URL Configuration (Site URL + Redirect URLs).
# SITE_URL=https://your-domain.example.com
